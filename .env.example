# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never exposed to the browser

# --- AI provider (any OpenAI-compatible endpoint: OpenAI, Groq, Together, Mistral, Ollama...) ---
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000   # set to the production URL after deploy (used in QR codes)

# --- Email notifications (νέα αιτήματα επισκεπτών → email στον ιδιοκτήτη) ---
# console (default): γράφει το email στο log — ιδανικό για development
# resend:   πραγματικά emails μέσω Resend   (χρειάζεται RESEND_API_KEY)
# sendgrid: πραγματικά emails μέσω SendGrid (χρειάζεται SENDGRID_API_KEY)
EMAIL_PROVIDER=console
# RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG...
# EMAIL_FROM=GuestFlow <notifications@yourdomain.com>
